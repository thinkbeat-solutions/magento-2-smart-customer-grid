<?xml version="1.0"?>
<!--
/**
 * Thinkbeat_SmartCustomerGrid Customer Listing UI Component Configuration
 *
 * Enhances the admin customer grid with additional business insight columns
 *
 * @category  Thinkbeat
 * @package   Thinkbeat_SmartCustomerGrid
 * @author    Thinkbeat
 * @copyright Copyright (c) 2026 Thinkbeat
 */
-->
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    
    <columns name="customer_columns">
        
        <!-- Total Orders Count Column -->
        <column name="total_orders" class="Magento\Ui\Component\Listing\Columns\Column" sortOrder="100">
            <settings>
                <label translate="true">Total Orders</label>
                <filter>number</filter>
                <dataType>number</dataType>
                <visible>true</visible>
            </settings>
        </column>

        <!-- Lifetime Value Column -->
        <column name="lifetime_value" class="Thinkbeat\SmartCustomerGrid\Ui\Component\Listing\Column\LifetimeValue" sortOrder="110">
            <settings>
                <label translate="true">Lifetime Value</label>
                <filter>textRange</filter>
                <dataType>text</dataType>
                <visible>true</visible>
            </settings>
        </column>

        <!-- Last Order Date Column -->
        <column name="last_order_date" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date" sortOrder="120">
            <settings>
                <label translate="true">Last Order Date</label>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <visible>true</visible>
                <timezone>false</timezone>
                <dateFormat>MMM d, y</dateFormat>
                <resizeEnabled>true</resizeEnabled>
                <resizeDefaultWidth>150</resizeDefaultWidth>
                <headerTmpl>ui/grid/columns/text</headerTmpl>
                <fieldClass>
                    <class name="customers-last-order-column">true</class>
                </fieldClass>
            </settings>
        </column>

        <!-- Last Purchased Items Column -->
        <column name="last_purchased_items" class="Thinkbeat\SmartCustomerGrid\Ui\Component\Listing\Column\LastPurchasedItems" sortOrder="130">
            <settings>
                <label translate="true">Last Purchased Items</label>
                <filter>false</filter>
                <sortable>false</sortable>
                <visible>true</visible>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
                <resizeEnabled>true</resizeEnabled>
                <resizeDefaultWidth>400</resizeDefaultWidth>
                <headerTmpl>ui/grid/columns/text</headerTmpl>
                <fieldClass>
                    <class name="customers-items-column">true</class>
                </fieldClass>
            </settings>
        </column>

        <!-- Customer Type Column -->
        <column name="customer_type" class="Thinkbeat\SmartCustomerGrid\Ui\Component\Listing\Column\CustomerType" sortOrder="150">
            <settings>
                <label translate="true">Customer Type</label>
                <filter>select</filter>
                <dataType>select</dataType>
                <visible>true</visible>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
                <options class="Thinkbeat\SmartCustomerGrid\Model\Source\CustomerType"/>
            </settings>
        </column>

        <!-- Is Guest Customer Column (Hidden, for JS logic) -->
        <column name="is_guest_customer" class="Magento\Ui\Component\Listing\Columns\Column" sortOrder="155">
            <settings>
                <label translate="true">Is Guest</label>
                <filter>false</filter>
                <dataType>boolean</dataType>
                <visible>false</visible>
            </settings>
        </column>

        <!-- Email Domain Column -->
        <column name="email_domain" class="Magento\Ui\Component\Listing\Columns\Column" sortOrder="160">
            <settings>
                <label translate="true">Email Domain</label>
                <filter>text</filter>
                <dataType>text</dataType>
                <visible>false</visible>
            </settings>
        </column>

    </columns>
</listing>
